              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (pm.response.code === 201 && response.success && response.data.token) {",
                  "    pm.collectionVariables.set('token', response.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
