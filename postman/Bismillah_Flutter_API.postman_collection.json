              "raw": "{\n  \"username\": \"pasien01\",\n  \"email\": \"pasien@example.com\",\n  \"password\": \"Password123!\",\n  \"password_confirmation\": \"Password123!\",\n  \"name\": \"Pasien Contoh\",\n  \"phone\": \"081234567890\",\n  \"address\": \"Jl. Sehat No. 1\",\n  \"device_name\": \"Postman\"\n}",
